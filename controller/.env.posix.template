BEATLED_SERVER_NAME=localhost
NUM_PIXELS=30

# Running several simulator instances on one machine:
# the server identifies controllers by source IP, so give each instance a
# distinct local address at launch via BEATLED_BIND_ADDR. This is a RUNTIME
# env var (not baked in at build time), so it can differ per instance:
#   BEATLED_BIND_ADDR=127.0.0.1 ./beatled.sh controller posix build
#   BEATLED_BIND_ADDR=127.0.0.2 ./beatled.sh controller posix build
# Unset means INADDR_ANY (fine for a single instance, but it claims the port on
# every address, so running multiple instances requires an explicit address for
# each). On macOS only 127.0.0.1 exists by default; add extra loopback aliases
# once per boot before using them:
#   sudo ifconfig lo0 alias 127.0.0.2 up
#   sudo ifconfig lo0 alias 127.0.0.3 up
