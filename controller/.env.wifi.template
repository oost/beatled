# Shared WiFi config — the single source of truth for both the controller
# firmware (baked into the .uf2 / esp32 image at build time) and the
# Raspberry Pi host's wifi-fallback service (server deploy).
#
# Copy this file to .env.wifi and fill it in. Quote any value containing
# spaces or shell metacharacters, e.g.
#   WIFI_SSID="My Home Network"
# (this file is sourced by the shell, like the other .env files).
#
# ── Upstream networks ────────────────────────────────────────────────
# Infrastructure WiFi that everything joins as a client, in priority
# order. WIFI_SSID is primary; _2.._4 are optional fallbacks tried in
# order. Leave a slot blank to disable it.
#
# Controllers connect to these by SSID. The Pi host's wifi-fallback
# service activates the NetworkManager profile whose *name* matches each
# SSID (the default when created via `nmcli dev wifi connect "<SSID>"`).

WIFI_SSID=
WIFI_PASSWORD=
WIFI_SSID_2=
WIFI_PASSWORD_2=
WIFI_SSID_3=
WIFI_PASSWORD_3=
WIFI_SSID_4=
WIFI_PASSWORD_4=

# ── Fallback hotspot ─────────────────────────────────────────────────
# The Pi's self-hosted network for when no upstream WiFi is reachable.
# This is ONE network seen from two sides:
#   • The Pi *broadcasts* it (an AP-mode NetworkManager profile named by
#     HOTSPOT_CON), so the host never tries to join it.
#   • Controllers *join* it as their last-resort network, so the firmware
#     build appends HOTSPOT_SSID/HOTSPOT_PASSWORD after the upstream list.
# HOTSPOT_PASSWORD must match the password configured in the HOTSPOT_CON
# profile on the Pi. Leave HOTSPOT_SSID blank to disable the hotspot
# fallback entirely.

HOTSPOT_SSID=
HOTSPOT_PASSWORD=
# Pi host only: name of the AP-mode NetworkManager profile that broadcasts
# HOTSPOT_SSID. Ignored by the firmware builds. Default: beatled-hotspot.
#HOTSPOT_CON=beatled-hotspot
