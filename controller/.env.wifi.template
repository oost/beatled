# Shared WiFi networks — the single source of truth for both the
# controller firmware (baked into the .uf2 / esp32 image at build time)
# and the Raspberry Pi host's wifi-fallback service (server deploy).
#
# Copy this file to .env.wifi and fill in your networks. The first is
# the primary; 2-4 are optional fallbacks tried in order. Leave a slot
# blank to disable it.
#
# Quote any value containing spaces or shell metacharacters, e.g.
#   WIFI_SSID="My Home Network"
# (this file is sourced by the shell, like the other .env files).
#
# Controllers connect as WiFi clients using these SSID/password pairs.
# The Pi host's wifi-fallback service activates NetworkManager connection
# profiles *by name*, assuming a profile exists whose name matches each
# SSID (the default when a profile is created via `nmcli dev wifi connect
# "<SSID>"`). The passwords here are only used by the firmware build.

WIFI_SSID=
WIFI_PASSWORD=
WIFI_SSID_2=
WIFI_PASSWORD_2=
WIFI_SSID_3=
WIFI_PASSWORD_3=
WIFI_SSID_4=
WIFI_PASSWORD_4=

# Pi host only: NetworkManager hotspot profile to fall back to when no
# WiFi connects. Ignored by the firmware builds. Default: beatled-hotspot.
#HOTSPOT_CON=hotspot
